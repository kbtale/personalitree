# ============================================================
# PersonaliTree – Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=personalitree
POSTGRES_USER=personalitree
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------- Django ----------
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ---------- LLM API Keys (configure at least one) ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---------- Proxy (optional) ----------
PROXY_URL=

# ---------- Data Retention ----------
# Set to "ephemeral" to auto-purge raw scrapes after session ends
RETENTION_MODE=persistent
